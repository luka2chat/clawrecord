{
  "name": "clawrecord",
  "version": "1.0.0",
  "description": "Gamified OpenClaw tracking — XP, achievements, leagues, global leaderboard",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl",
    "collect": "python3 scripts/collect.py",
    "score": "python3 scripts/score.py",
    "generate": "python3 scripts/generate_pages.py",
    "refresh": "python3 scripts/collect.py && python3 scripts/score.py && python3 scripts/generate_pages.py",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "python3 -m pytest tests/unit/ -v",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "build": {
    "appId": "com.clawrecord.app",
    "productName": "ClawRecord",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "docs/**/*",
      "scripts/**/*",
      "data/**/*",
      "hooks/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "hooks",
        "to": "hooks",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "keywords": [
    "openclaw",
    "gamification",
    "tracking",
    "electron",
    "desktop"
  ],
  "author": "ClawRecord Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2"
  }
}
